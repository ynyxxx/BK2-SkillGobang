{
  "name": "skill-gobang-backend",
  "version": "1.0.0",
  "description": "Skill Gobang Backend with AI",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "test:ai": "tsx src/ai/testGobangAI.ts",
    "test:mcp": "tsx src/mcp/test-mcp.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "mcp": "tsx src/mcp/gobangMCP.ts",
    "mcp:inspect": "npx @modelcontextprotocol/inspector tsx src/mcp/gobangMCP.ts"
  },
  "keywords": [
    "gobang",
    "五子棋",
    "ai",
    "game",
    "mcp"
  ],
  "author": "BK2 Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "socket.io": "^4.6.1"
  }
}
