# Skill Gobang 后端环境变量配置
# 复制此文件为 .env 并填入你的 API Key

PORT=3001
FRONTEND_URL=http://localhost:3000

# ====== AI 提供者配置 ======
# 设置默认 AI 提供者（不设置则只用内置GobangAI）
# 可选值: openai | claude | deepseek | ollama | gobang-only
DEFAULT_AI_PROVIDER=gobang-only

# ====== OpenAI ======
# 支持 GPT-4o, GPT-4o-mini, GPT-3.5-turbo 等
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# 可自定义 BaseURL 接入兼容 OpenAI 协议的服务
OPENAI_BASE_URL=https://api.openai.com/v1

# ====== Anthropic Claude ======
# 支持 claude-3-5-sonnet-20241022, claude-haiku-4-5-20251001 等
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ====== DeepSeek ======
DEEPSEEK_API_KEY=

# ====== Ollama (本地模型) ======
# 需先安装 Ollama: https://ollama.ai
# 然后运行: ollama pull qwen2:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b
